# Phoenix runtime
PHX_SERVER=true
PHX_HOST=localhost
PORT=4000
SECRET_KEY_BASE=replace-with-generated-secret

# MongoDB runtime
MONGO_URL=mongodb://localhost:27017/ocpp_simulator_dev
MONGO_DATABASE=ocpp_simulator_dev
MONGO_POOL_SIZE=10

# Simulator runtime limits
MAX_CONCURRENT_RUNS=25
MAX_ACTIVE_SESSIONS=200
WS_RETRY_BASE_DELAY_MS=1000
WS_MAX_RECONNECT_ATTEMPTS=3
WS_OUTBOUND_MAX_QUEUE_SIZE=200
WS_OUTBOUND_MAX_IN_FLIGHT=8
WS_OUTBOUND_MAX_RETRY_ATTEMPTS=3
WS_OUTBOUND_RETRY_BASE_DELAY_MS=200
WEBHOOK_DELIVERY_TIMEOUT_MS=5000
WEBHOOK_DELIVERY_DEFAULT_MAX_ATTEMPTS=3
WEBHOOK_DELIVERY_DEFAULT_BACKOFF_MS=1000
